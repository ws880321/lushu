.alert-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  margin-bottom: 12rpx;
  border-radius: 8rpx;
}

.alert-item.critical {
  background: #fff0f0;
  border-left: 4rpx solid #e53935;
}

.alert-item.warning {
  background: #fff8e1;
  border-left: 4rpx solid #ff9800;
}

.alert-item.info {
  background: #e3f2fd;
  border-left: 4rpx solid #2196f3;
}

.alert-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.alert-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.alert-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.alert-desc {
  font-size: 24rpx;
  color: #888;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.alert-dist {
  font-size: 22rpx;
  color: #666;
  margin-top: 2rpx;
}
