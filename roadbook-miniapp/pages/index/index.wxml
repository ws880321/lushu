<view class="container">
  <view class="header">
    <text class="greeting">🚙 我的自驾路书</text>
  </view>
  <view class="quick-actions">
    <view class="action-btn gen" bindtap="goGenerate"><text>🗺️ 生成路书</text></view>
    <view class="action-btn rec" bindtap="goRecord"><text>📍 记录行程</text></view>
  </view>
  <view class="section">
    <text class="section-title">📋 我的路书</text>
    <view wx:if="{{myRoutes.length===0}}" class="empty-hint">暂无路书，去生成一条吧 🚀</view>
    <view class="route-card" wx:for="{{myRoutes}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <text class="route-title">{{item.title}}</text>
      <text class="route-meta">{{item.totalDays}}天 · {{item.totalDistance||'--'}}km</text>
    </view>
  </view>
  <view class="section">
    <text class="section-title">🔥 热门路线</text>
    <scroll-view scroll-x class="hot-scroll">
      <view class="hot-card" wx:for="{{hotRoutes}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
        <text class="hot-name">{{item.name||item.title}}</text>
        <text class="hot-meta">{{item.region||''}} · {{item.totalDays}}天</text>
      </view>
    </scroll-view>
  </view>
</view>
