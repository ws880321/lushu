.container { padding: 24rpx; }
.header { padding: 32rpx 0 16rpx; }
.greeting { font-size: 40rpx; font-weight: 700; color: #2E7D32; display: block; }
.quick-actions { display: flex; gap: 24rpx; margin: 24rpx 0; }
.action-btn { flex: 1; padding: 32rpx; border-radius: 16rpx; text-align: center; font-size: 30rpx; font-weight: 600; color: #fff; }
.action-btn.gen { background: linear-gradient(135deg, #2E7D32, #388E3C); }
.action-btn.rec { background: linear-gradient(135deg, #1565C0, #1976D2); }
.section { margin-top: 32rpx; }
.section-title { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; display: block; }
.empty-hint { color: #999; font-size: 28rpx; padding: 32rpx 0; text-align: center; }
.route-card { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 12rpx; display: flex; justify-content: space-between; align-items: center; }
.route-title { font-size: 30rpx; font-weight: 500; color: #333; }
.route-meta { font-size: 24rpx; color: #999; margin-top: 4rpx; }
.hot-scroll { white-space: nowrap; padding: 8rpx 0; }
.hot-card { display: inline-flex; flex-direction: column; width: 200rpx; padding: 24rpx; border-radius: 16rpx; background: #e8f5e9; margin-right: 16rpx; }
.hot-name { font-size: 26rpx; font-weight: 600; color: #333; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.hot-meta { font-size: 22rpx; color: #888; margin-top: 4rpx; }
