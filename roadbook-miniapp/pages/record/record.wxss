.container { padding: 24rpx; padding-bottom: 120rpx; }
.card { background: #fff; border-radius: 24rpx; padding: 32rpx; margin-bottom: 24rpx; }
.card-title { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 24rpx; }
.input { background: #f5f5f5; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; margin-bottom: 16rpx; }
.type-row, .day-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.label { font-size: 28rpx; color: #666; }
.picker-val { font-size: 28rpx; color: #2E7D32; }
.stepper { display: flex; align-items: center; gap: 20rpx; font-size: 32rpx; }
.step-btn { width: 48rpx; height: 48rpx; border-radius: 50%; border: 2rpx solid #2E7D32; display: flex; align-items: center; justify-content: center; color: #2E7D32; }
.loc-btn { background: #e3f2fd; color: #1565C0; font-size: 26rpx; margin-bottom: 16rpx; }
.save-btn { background: #2E7D32; color: #fff; font-weight: 600; }
.finish-btn { background: #E65100; color: #fff; font-weight: 600; margin-top: 16rpx; }
.rec-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; gap: 16rpx; }
.rec-type { padding: 4rpx 12rpx; background: #e8f5e9; border-radius: 8rpx; font-size: 22rpx; color: #2E7D32; }
.rec-name { flex: 1; font-size: 28rpx; }
.rec-day { font-size: 24rpx; color: #999; }
