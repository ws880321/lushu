.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

/* Map area */
.map-area {
  position: relative;
  height: 460rpx;
  flex-shrink: 0;
}

.map-overlay {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  right: 16rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.overlay-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  display: block;
}

.overlay-info {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
  display: block;
}

/* Day tabs */
.day-tabs {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  right: 16rpx;
  white-space: nowrap;
}

.day-tab {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  background: rgba(255, 255, 255, 0.9);
  margin-right: 12rpx;
  backdrop-filter: blur(8px);
}

.day-tab.active {
  background: #2E7D32;
  color: #fff;
  font-weight: 500;
}

/* Timeline */
.timeline {
  flex: 1;
  padding: 24rpx;
  background: #f5f5f5;
}

.day-header {
  padding: 16rpx 0 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.waypoint {
  display: flex;
  margin-bottom: 8rpx;
}

.wp-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100rpx;
  flex-shrink: 0;
}

.wp-time {
  font-size: 22rpx;
  color: #999;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.wp-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #2E7D32;
  flex-shrink: 0;
  z-index: 1;
}

.wp-dot.break {
  background: #FF9800;
  width: 16rpx;
  height: 16rpx;
}

.wp-line {
  width: 2rpx;
  flex: 1;
  background: #ddd;
  min-height: 40rpx;
}

.wp-content {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-left: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.04);
}

.wp-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.wp-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.wp-type {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: #e8f5e9;
  color: #2E7D32;
  margin-left: 12rpx;
}

.wp-type.restaurant {
  background: #fff3e0;
  color: #E65100;
}

.wp-type.scenic {
  background: #e3f2fd;
  color: #1565C0;
}

.wp-type.gas {
  background: #fce4ec;
  color: #C62828;
}

.wp-type.hotel {
  background: #f3e5f5;
  color: #6A1B9A;
}

.wp-desc {
  font-size: 24rpx;
  color: #888;
  margin-top: 12rpx;
  display: block;
}

.wp-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #aaa;
}

/* Break special */
.waypoint.break .wp-dot {
  background: #FF9800;
}

/* Skeleton */
.skeleton { display: flex; flex-direction: column; height: 100vh; overflow: hidden; background: #f5f5f5; }
.sk-map { height: 460rpx; flex-shrink: 0; background: linear-gradient(110deg, #e0e0e0 30%, #f0f0f0 50%, #e0e0e0 70%); background-size: 200% 100%; animation: shimmer 1.5s ease-in-out infinite; }
.sk-overlay { position: absolute; top: 16rpx; left: 16rpx; right: 16rpx; background: rgba(255,255,255,.9); border-radius: 16rpx; padding: 20rpx 24rpx; }
.sk-tabs { display: flex; gap: 12rpx; padding: 16rpx 16rpx 0; }
.sk-pill { width: 120rpx; height: 56rpx; border-radius: 40rpx; background: linear-gradient(110deg, #e0e0e0 30%, #f0f0f0 50%, #e0e0e0 70%); background-size: 200% 100%; animation: shimmer 1.5s ease-in-out infinite; }
.sk-timeline { flex: 1; padding: 24rpx; }
.sk-wp { display: flex; gap: 20rpx; margin-bottom: 24rpx; }
.sk-dot-col { display: flex; flex-direction: column; align-items: center; width: 40rpx; flex-shrink: 0; }
.sk-dot { width: 20rpx; height: 20rpx; border-radius: 50%; background: #d8d8d8; }
.sk-vline { width: 4rpx; flex: 1; min-height: 60rpx; background: #e8e8e8; margin-top: 8rpx; }
.sk-card { flex: 1; background: #fff; border-radius: 16rpx; padding: 24rpx; display: flex; flex-direction: column; gap: 12rpx; }
.sk-line { height: 24rpx; border-radius: 8rpx; background: linear-gradient(110deg, #e0e0e0 30%, #f0f0f0 50%, #e0e0e0 70%); background-size: 200% 100%; animation: shimmer 1.5s ease-in-out infinite; }
.sk-w60 { width: 60%; } .sk-w40 { width: 40%; } .sk-w70 { width: 70%; } .sk-w30 { width: 30%; } .sk-w50 { width: 50%; }
.sk-short { height: 18rpx; }

@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
