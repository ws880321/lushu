.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* Point row */
.input-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.point-input { flex: 1; height: 72rpx; background: #f5f5f5; border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; }
.picker-btn, .map-btn { height: 72rpx; font-size: 24rpx; display: flex; align-items: center; }
.picker-btn { background: #e8f5e9; color: #2E7D32; }
.map-btn { background: #e3f2fd; color: #1565C0; }
.selected-hint { padding: 12rpx 0; font-size: 24rpx; color: #2E7D32; }
.connector { text-align: center; color: #ccc; font-size: 28rpx; padding: 4rpx 0; }
.picker-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 100; }
.picker-mask { width: 100%; height: 100%; background: rgba(0,0,0,0.4); }
.picker-body { position: absolute; bottom: 0; left: 0; right: 0; background: #fff; border-radius: 24rpx 24rpx 0 0; padding: 20rpx 0; }
.picker-header { display: flex; justify-content: space-between; padding: 16rpx 32rpx; font-size: 30rpx; }
.picker-header text:last-child { color: #2E7D32; font-weight: 600; }

.point-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  min-height: 56rpx;
}

.point-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.point-icon.start {
  background-color: #2E7D32;
}

.point-icon.end {
  background-color: #E65100;
}

.point-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.point-text.placeholder {
  color: #bbb;
}

.connector {
  width: 2rpx;
  height: 24rpx;
  background-color: #ddd;
  margin-left: 21rpx;
}

/* Stepper */
.stepper-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.stepper {
  display: flex;
  align-items: center;
}

.step-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid #2E7D32;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #2E7D32;
}

.step-btn:active {
  background-color: #e8f5e9;
}

.step-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin: 0 28rpx;
  min-width: 48rpx;
  text-align: center;
}

/* Difficulty */
.section-label {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 16rpx;
  margin-top: 16rpx;
}

.difficulty-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.diff-pill {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
}

.diff-pill.active {
  background: #2E7D32;
  color: #fff;
  font-weight: 500;
}

.diff-pill:active {
  opacity: 0.8;
}

/* Tags */
.tag-scroll {
  white-space: nowrap;
  margin-bottom: 8rpx;
  padding: 8rpx 0;
}

.tag-chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  margin-right: 16rpx;
}

.tag-chip.active {
  background: #e8f5e9;
  color: #2E7D32;
  font-weight: 500;
}

/* Slider */
.slider-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.slider-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #2E7D32;
}

/* Templates */
.template-scroll {
  white-space: nowrap;
  padding: 8rpx 0;
}

.template-card {
  display: inline-flex;
  flex-direction: column;
  width: 220rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #e8f5e9, #f1f8e9);
  margin-right: 20rpx;
}

.tpl-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tpl-region {
  font-size: 22rpx;
  color: #888;
  margin: 8rpx 0 4rpx;
}

.tpl-days {
  font-size: 22rpx;
  color: #2E7D32;
  font-weight: 500;
}

/* Vehicle */
.vehicle-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.vehicle-text {
  font-size: 26rpx;
  color: #666;
}

/* Generate button */
.generate-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #2E7D32, #388E3C);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 44rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.35);
  position: fixed;
  bottom: 32rpx;
  left: 24rpx;
  width: calc(100% - 48rpx);
}

.generate-btn::after {
  border: none;
}

.generate-btn:active {
  opacity: 0.9;
}

.generate-btn[disabled] {
  opacity: 0.6;
}
