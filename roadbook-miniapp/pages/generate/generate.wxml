<view class="container">
  <!-- 起终点 -->
  <view class="card">
    <view class="card-title">📍 起终点</view>
    <view class="point-row" bindtap="onStartTap">
      <view class="point-icon start">起</view>
      <text class="point-text {{startName?'':'placeholder'}}">{{startName || '点击地图选点（模拟器可输坐标）'}}</text>
    </view>
    <!-- 手动坐标输入 -->
    <view wx:if="{{showStartInput}}" class="coord-input">
      <input placeholder="经度,纬度 如 104.0657,30.6574" value="{{startCoordInput}}" bindinput="e=>startCoordInput=e.detail.value" confirm-type="done" bindconfirm="onStartCoordSubmit" />
      <button size="mini" bindtap="onStartCoordSubmit">确定</button>
    </view>
    <view class="connector">┃</view>
    <view class="point-row" bindtap="onEndTap">
      <view class="point-icon end">终</view>
      <text class="point-text {{endName?'':'placeholder'}}">{{endName || '点击地图选点（可选）'}}</text>
    </view>
    <view wx:if="{{showEndInput}}" class="coord-input">
      <input placeholder="经度,纬度" value="{{endCoordInput}}" bindinput="e=>endCoordInput=e.detail.value" confirm-type="done" bindconfirm="onEndCoordSubmit" />
      <button size="mini" bindtap="onEndCoordSubmit">确定</button>
    </view>
    <!-- 快捷城市 -->
    <view class="quick-row">
      <text class="label">快捷起点:</text>
      <scroll-view scroll-x class="quick-scroll">
        <view class="quick-chip" wx:for="{{quickCities}}" wx:key="name" data-index="{{index}}" bindtap="onQuickLoc">{{item.name}}</view>
      </scroll-view>
    </view>
    <view class="stepper-row">
      <text class="label">行程天数</text>
      <view class="stepper">
        <view class="step-btn" bindtap="onDayMinus">−</view>
        <text class="step-value">{{totalDays}}</text>
        <view class="step-btn" bindtap="onDayPlus">+</view>
      </view>
    </view>
  </view>

  <!-- 偏好 -->
  <view class="card">
    <view class="card-title">🎯 偏好设置</view>
    <view class="section-label">难度</view>
    <view class="difficulty-row">
      <view class="diff-pill {{difficulty==='easy'?'active':''}}" data-diff="easy" bindtap="onDifficultyTap">轻松</view>
      <view class="diff-pill {{difficulty==='medium'?'active':''}}" data-diff="medium" bindtap="onDifficultyTap">中等</view>
      <view class="diff-pill {{difficulty==='hard'?'active':''}}" data-diff="hard" bindtap="onDifficultyTap">挑战</view>
    </view>
    <view class="section-label">兴趣标签</view>
    <scroll-view scroll-x class="tag-scroll">
      <view wx:for="{{allTags}}" wx:key="*this" class="tag-chip {{tags.indexOf(item)>-1?'active':''}}" data-tag="{{item}}" bindtap="onTagToggle">{{item}}</view>
    </scroll-view>
    <view class="section-label">每日驾驶时长</view>
    <text class="slider-value">{{dailyHours}}小时</text>
    <slider min="2" max="8" step="0.5" value="{{dailyHours}}" bindchange="onSliderChange" activeColor="#2E7D32" />
  </view>

  <!-- 热门模板 -->
  <view class="card" wx:if="{{popularTemplates.length}}">
    <view class="card-title">🔥 热门模板</view>
    <scroll-view scroll-x class="template-scroll">
      <view class="template-card" wx:for="{{popularTemplates}}" wx:key="id" data-template="{{item}}" bindtap="onTemplateTap">
        <text class="tpl-name">{{item.name}}</text>
        <text class="tpl-region">{{item.region}}</text>
        <text class="tpl-days">{{item.totalDays}}天</text>
      </view>
    </scroll-view>
  </view>

  <button class="generate-btn" bindtap="onGenerate" loading="{{generating}}" disabled="{{generating}}">
    🚀 生成我的路书
  </button>
</view>
