.dashboard {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* Mini map */
.mini-map-wrap {
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.location-label {
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 20rpx;
  text-align: center;
}

/* Card */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* Fuel status */
.status-card {
  background: linear-gradient(135deg, #e8f5e9, #f1f8e9);
}

.fuel-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.fuel-row > text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.fuel-text {
  font-size: 26rpx;
  color: #555;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.fuel-status.ok {
  color: #2E7D32;
}

.fuel-status.warn {
  color: #E53935;
}

.trip-row {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.trip-row text {
  font-size: 26rpx;
  color: #666;
}

/* Alert list */
.alert-list {
  margin-top: 8rpx;
}

/* Empty state */
.empty {
  text-align: center;
  padding: 48rpx 0;
  font-size: 28rpx;
  color: #bbb;
}

/* Caravan placeholder */
.caravan-placeholder {
  text-align: center;
}

.caravan-placeholder text {
  font-size: 28rpx;
  color: #999;
}
